KafkaProducerService.java
javapackage com.parking.payment.kafka;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Service;

@Slf4j
@Service
@RequiredArgsConstructor
public class KafkaProducerService {

    private final KafkaTemplate<String, Object> kafkaTemplate;

    public static final String PAYMENT_COMPLETED =
            "payment.completed";
    public static final String PAYMENT_FAILED =
            "payment.failed";

    public void publishPaymentCompleted(PaymentEvent event) {
        log.info("Publishing payment.completed: {}",
                event.getPaymentId());
        try {
            kafkaTemplate.send(PAYMENT_COMPLETED,
                    event.getPaymentId(), event);
        } catch (Exception e) {
            log.warn("Kafka publish failed: {}", e.getMessage());
        }
    }

    public void publishPaymentFailed(PaymentEvent event) {
        log.info("Publishing payment.failed: {}",
                event.getPaymentId());
        try {
            kafkaTemplate.send(PAYMENT_FAILED,
                    event.getPaymentId(), event);
        } catch (Exception e) {
            log.warn("Kafka publish failed: {}", e.getMessage());
        }
    }
}

Step 10 — Repository
PaymentRepository.java
javapackage com.parking.payment.repository;

import com.parking.payment.model.Payment;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.core.RowMapper;
import org.springframework.stereotype.Repository;

import java.util.List;
import java.util.Optional;

@Slf4j
@Repository
@RequiredArgsConstructor
public class PaymentRepository {

    private final JdbcTemplate jdbcTemplate;

    private final RowMapper<Payment> rowMapper = (rs, rowNum) ->
            Payment.builder()
                    .id(rs.getString("id"))
                    .bookingId(rs.getString("booking_id"))
                    .userId(rs.getString("user_id"))
                    .amount(rs.getBigDecimal("amount"))
                    .status(rs.getString("status"))
                    .transactionId(rs.getString("transaction_id"))
                    .paymentMode(rs.getString("payment_mode"))
                    .paidAt(rs.getTimestamp("paid_at") != null
                            ? rs.getTimestamp("paid_at")
                                    .toLocalDateTime() : null)
                    .createdAt(rs.getTimestamp("created_at")
                            .toLocalDateTime())
                    .build();

    public void save(Payment payment) {
        log.debug("Saving payment: {}", payment.getId());
        String sql = """
                INSERT INTO payments
                (id, booking_id, user_id, amount, status,
                 payment_mode, created_at)
                VALUES (?, ?, ?, ?, ?, ?, NOW())
                """;
        jdbcTemplate.update(sql,
                payment.getId(),
                payment.getBookingId(),
                payment.getUserId(),
                payment.getAmount(),
                payment.getStatus(),
                payment.getPaymentMode()
        );
    }

    public Optional<Payment> findById(String id) {
        String sql = "SELECT * FROM payments WHERE id = ?";
        return jdbcTemplate.query(sql, rowMapper, id)
                .stream().findFirst();
    }

    public Optional<Payment> findByBookingId(String bookingId) {
        String sql = """
                SELECT * FROM payments WHERE booking_id = ?
                """;
        return jdbcTemplate.query(sql, rowMapper, bookingId)
                .stream().findFirst();
    }

    public List<Payment> findByUserId(String userId,
                                       int offset, int size) {
        String sql = """
                SELECT * FROM payments
                WHERE user_id = ?
                ORDER BY created_at DESC
                LIMIT ? OFFSET ?
                """;
        return jdbcTemplate.query(sql, rowMapper,
                userId, size, offset);
    }

    public long countByUserId(String userId) {
        String sql = """
                SELECT COUNT(*) FROM payments
                WHERE user_id = ?
                """;
        Long count = jdbcTemplate.queryForObject(
                sql, Long.class, userId);
        return count != null ? count : 0;
    }

    public void updateStatus(String paymentId,
                              String status,
                              String transactionId) {
        log.debug("Updating payment status: {} → {}",
                paymentId, status);
        String sql = """
                UPDATE payments
                SET status = ?,
                    transaction_id = ?,
                    paid_at = CASE
                        WHEN ? = 'COMPLETED' THEN NOW()
                        ELSE paid_at END,
                    updated_at = NOW()
                WHERE id = ?
                """;
        jdbcTemplate.update(sql,
                status, transactionId, status, paymentId);
    }
}

Step 11 — PaymentService
javapackage com.parking.payment.service;

import com.parking.payment.dto.request.PaymentRequest;
import com.parking.payment.dto.response.PageResponse;
import com.parking.payment.dto.response.PaymentResponse;
import com.parking.payment.exception.ResourceNotFoundException;
import com.parking.payment.exception.ResourceAlreadyExistsException;
import com.parking.payment.kafka.KafkaProducerService;
import com.parking.payment.kafka.PaymentEvent;
import com.parking.payment.model.Payment;
import com.parking.payment.repository.PaymentRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.util.List;
import java.util.UUID;

@Slf4j
@Service
@RequiredArgsConstructor
public class PaymentService {

    private final PaymentRepository paymentRepository;
    private final KafkaProducerService kafkaProducerService;

    public PaymentResponse initiatePayment(String userId,
                                            PaymentRequest request) {
        log.info("Initiating payment for booking: {}",
                request.getBookingId());

        paymentRepository.findByBookingId(request.getBookingId())
                .ifPresent(p -> {
                    if (p.getStatus().equals("COMPLETED")) {
                        throw new ResourceAlreadyExistsException(
                            "Payment already completed for this booking");
                    }
                });

        Payment payment = Payment.builder()
                .id(UUID.randomUUID().toString())
                .bookingId(request.getBookingId())
                .userId(userId)
                .amount(request.getAmount())
                .status("PENDING")
                .paymentMode(request.getPaymentMode())
                .build();

        paymentRepository.save(payment);
        log.info("Payment initiated: {}", payment.getId());

        return processPayment(payment);
    }

    private PaymentResponse processPayment(Payment payment) {
        log.info("Processing payment: {}", payment.getId());

        try {
            String transactionId = "TXN-"
                    + UUID.randomUUID().toString()
                            .substring(0, 8).toUpperCase();

            paymentRepository.updateStatus(
                    payment.getId(), "COMPLETED", transactionId);

            log.info("Payment completed: {} txn: {}",
                    payment.getId(), transactionId);

            kafkaProducerService.publishPaymentCompleted(
                    PaymentEvent.builder()
                            .eventType("PAYMENT_COMPLETED")
                            .paymentId(payment.getId())
                            .bookingId(payment.getBookingId())
                            .userId(payment.getUserId())
                            .amount(payment.getAmount())
                            .status("COMPLETED")
                            .timestamp(LocalDateTime.now())
                            .build());

            return paymentRepository.findById(payment.getId())
                    .map(this::mapToResponse)
                    .orElseThrow();

        } catch (Exception e) {
            log.error("Payment failed: {}", e.getMessage());

            paymentRepository.updateStatus(
                    payment.getId(), "FAILED", null);

            kafkaProducerService.publishPaymentFailed(
                    PaymentEvent.builder()
                            .eventType("PAYMENT_FAILED")
                            .paymentId(payment.getId())
                            .bookingId(payment.getBookingId())
                            .userId(payment.getUserId())
                            .amount(payment.getAmount())
                            .status("FAILED")
                            .timestamp(LocalDateTime.now())
                            .build());

            return paymentRepository.findById(payment.getId())
                    .map(this::mapToResponse)
                    .orElseThrow();
        }
    }

    public PaymentResponse getPaymentById(String paymentId) {
        log.info("Fetching payment: {}", paymentId);
        return paymentRepository.findById(paymentId)
                .map(this::mapToResponse)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Payment not found: " + paymentId));
    }

    public PaymentResponse getPaymentByBookingId(
            String bookingId) {
        log.info("Fetching payment for booking: {}", bookingId);
        return paymentRepository.findByBookingId(bookingId)
                .map(this::mapToResponse)
                .orElseThrow(() -> new ResourceNotFoundException(
                        "Payment not found for booking: "
                                + bookingId));
    }

    public PageResponse<PaymentResponse> getMyPayments(
            String userId, int page, int size) {
        log.info("Fetching payments for user: {}", userId);

        int offset = page * size;

        List<PaymentResponse> payments = paymentRepository
                .findByUserId(userId, offset, size)
                .stream()
                .map(this::mapToResponse)
                .toList();

        long total = paymentRepository.countByUserId(userId);
        int totalPages = (int) Math.ceil(
                (double) total / size);

        return PageResponse.<PaymentResponse>builder()
                .content(payments)
                .page(page)
                .size(size)
                .totalElements(total)
                .totalPages(totalPages)
                .isFirst(page == 0)
                .isLast(page >= totalPages - 1)
                .build();
    }

    private PaymentResponse mapToResponse(Payment payment) {
        return PaymentResponse.builder()
                .id(payment.getId())
                .bookingId(payment.getBookingId())
                .userId(payment.getUserId())
                .amount(payment.getAmount())
                .status(payment.getStatus())
                .transactionId(payment.getTransactionId())
                .paymentMode(payment.getPaymentMode())
                .paidAt(payment.getPaidAt())
                .createdAt(payment.getCreatedAt())
                .build();
    }
}

