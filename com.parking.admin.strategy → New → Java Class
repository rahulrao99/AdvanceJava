package com.parking.admin.strategy;

import com.parking.admin.dto.response.GateResponse;
import com.parking.admin.dto.response.NearestGateResponse;
import com.parking.admin.model.EntryExitGate;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Component;

import java.util.Comparator;
import java.util.List;

@Slf4j
@Component
public class HaversineGateStrategy implements GateSelectionStrategy {

    private static final double EARTH_RADIUS_KM = 6371.0;

    @Override
    public NearestGateResponse findNearestGates(
            List<EntryExitGate> gates,
            Double userLat,
            Double userLon) {

        log.debug("Finding nearest gates for location: {}, {}", 
                  userLat, userLon);

        List<EntryExitGate> activeGates = gates.stream()
                .filter(EntryExitGate::isActive)
                .toList();

        EntryExitGate nearestEntry = activeGates.stream()
                .filter(g -> g.getGateType().equals("ENTRY")
                          || g.getGateType().equals("BOTH"))
                .min(Comparator.comparingDouble(g ->
                        calculateDistance(userLat, userLon,
                                g.getLatitude(), g.getLongitude())))
                .orElse(null);

        EntryExitGate nearestExit = activeGates.stream()
                .filter(g -> g.getGateType().equals("EXIT")
                          || g.getGateType().equals("BOTH"))
                .min(Comparator.comparingDouble(g ->
                        calculateDistance(userLat, userLon,
                                g.getLatitude(), g.getLongitude())))
                .orElse(null);

        Double entryDistance = nearestEntry != null
                ? calculateDistance(userLat, userLon,
                        nearestEntry.getLatitude(),
                        nearestEntry.getLongitude())
                : null;

        Double exitDistance = nearestExit != null
                ? calculateDistance(userLat, userLon,
                        nearestExit.getLatitude(),
                        nearestExit.getLongitude())
                : null;

        return NearestGateResponse.builder()
                .nearestEntryGate(nearestEntry != null
                        ? mapToGateResponse(nearestEntry) : null)
                .nearestExitGate(nearestExit != null
                        ? mapToGateResponse(nearestExit) : null)
                .distanceToEntryGate(entryDistance)
                .distanceToExitGate(exitDistance)
                .build();
    }

    private double calculateDistance(double lat1, double lon1,
                                     double lat2, double lon2) {
        double dLat = Math.toRadians(lat2 - lat1);
        double dLon = Math.toRadians(lon2 - lon1);

        double a = Math.sin(dLat / 2) * Math.sin(dLat / 2)
                + Math.cos(Math.toRadians(lat1))
                * Math.cos(Math.toRadians(lat2))
                * Math.sin(dLon / 2) * Math.sin(dLon / 2);

        double c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));

        return EARTH_RADIUS_KM * c;
    }

    private GateResponse mapToGateResponse(EntryExitGate gate) {
        return GateResponse.builder()
                .id(gate.getId())
                .lotId(gate.getLotId())
                .gateType(gate.getGateType())
                .gateCode(gate.getGateCode())
                .latitude(gate.getLatitude())
                .longitude(gate.getLongitude())
                .isActive(gate.isActive())
                .build();
    }
}
