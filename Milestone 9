## 📁 File 2: `src/tests/MovieCard.test.js`

```javascript
import React from 'react';
import { render, screen, fireEvent } from '@testing-library/react';
import { MemoryRouter } from 'react-router-dom';
import MovieCard from '../components/MovieCard';

const mockNavigate = jest.fn();
jest.mock('react-router-dom', () => ({
  ...jest.requireActual('react-router-dom'),
  useNavigate: () => mockNavigate,
}));

const mockMovie = {
  imdbID: 'tt0372784',
  Title: 'Batman Begins',
  Year: '2005',
  Poster: 'https://example.com/batman.jpg',
  imdbRating: '8.2',
};

const mockMovieNoPoster = {
  imdbID: 'tt9999999',
  Title: 'No Poster Movie',
  Year: '2023',
  Poster: 'N/A',
  imdbRating: 'N/A',
};

describe('MovieCard Component', () => {

  beforeEach(() => {
    mockNavigate.mockClear();
  });

  test('renders movie title and year', () => {
    render(<MemoryRouter><MovieCard movie={mockMovie} /></MemoryRouter>);
    expect(screen.getByText('Batman Begins')).toBeInTheDocument();
    expect(screen.getByText('2005')).toBeInTheDocument();
  });

  test('renders movie poster image', () => {
    render(<MemoryRouter><MovieCard movie={mockMovie} /></MemoryRouter>);
    const img = screen.getByAltText('Batman Begins');
    expect(img).toBeInTheDocument();
    expect(img).toHaveAttribute('src', mockMovie.Poster);
  });

  test('shows No Poster fallback when poster is N/A', () => {
    render(<MemoryRouter><MovieCard movie={mockMovieNoPoster} /></MemoryRouter>);
    expect(screen.getByText('No Poster Available')).toBeInTheDocument();
  });

  test('navigates to movie detail page on click', () => {
    render(<MemoryRouter><MovieCard movie={mockMovie} /></MemoryRouter>);
    fireEvent.click(screen.getByText('Batman Begins'));
    expect(mockNavigate).toHaveBeenCalledWith('/movie/tt0372784');
  });

  test('renders imdb rating', () => {
    render(<MemoryRouter><MovieCard movie={mockMovie} /></MemoryRouter>);
    expect(screen.getByText('8.2')).toBeInTheDocument();
  });

  test('renders N/A when rating not available', () => {
    render(<MemoryRouter><MovieCard movie={mockMovieNoPoster} /></MemoryRouter>);
    expect(screen.getByText('N/A')).toBeInTheDocument();
  });

});
