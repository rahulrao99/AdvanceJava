## 📁 File 5: `src/tests/movieService.test.js`

```javascript
import axios from 'axios';
import { searchMovies, getMovieById } from '../services/movieService';

jest.mock('axios');

const mockSearchResponse = {
  data: {
    Response: 'True',
    Search: [
      { imdbID: 'tt0372784', Title: 'Batman Begins', Year: '2005', Poster: 'N/A' },
    ],
  },
};

const mockDetailResponse = {
  data: {
    Response: 'True',
    imdbID: 'tt0372784',
    Title: 'Batman Begins',
    Year: '2005',
    Plot: 'A great movie',
    imdbRating: '8.2',
  },
};

describe('movieService', () => {

  beforeEach(() => {
    jest.clearAllMocks();
  });

  test('searchMovies returns movie list on success', async () => {
    axios.create.mockReturnValue({
      get: jest.fn().mockResolvedValue(mockSearchResponse),
    });
    const movies = await searchMovies('batman');
    expect(movies).toHaveLength(1);
    expect(movies[0].Title).toBe('Batman Begins');
  });

  test('searchMovies throws error when Response is False', async () => {
    axios.create.mockReturnValue({
      get: jest.fn().mockResolvedValue({
        data: { Response: 'False', Error: 'Movie not found!' },
      }),
    });
    await expect(searchMovies('xyzxyz')).rejects.toThrow('Movie not found!');
  });

  test('getMovieById returns movie details on success', async () => {
    axios.create.mockReturnValue({
      get: jest.fn().mockResolvedValue(mockDetailResponse),
    });
    const movie = await getMovieById('tt0372784');
    expect(movie.Title).toBe('Batman Begins');
    expect(movie.imdbRating).toBe('8.2');
  });

  test('getMovieById throws error when Response is False', async () => {
    axios.create.mockReturnValue({
      get: jest.fn().mockResolvedValue({
        data: { Response: 'False', Error: 'Movie not found!' },
      }),
    });
    await expect(getMovieById('invalid')).rejects.toThrow('Movie not found!');
  });

});
```

