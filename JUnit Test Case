javapackage com.parking.booking.service;

import com.parking.booking.dto.request.BookingRequest;
import com.parking.booking.dto.request.VehicleExitRequest;
import com.parking.booking.dto.response.BookingResponse;
import com.parking.booking.dto.response.FeeConfigResponse;
import com.parking.booking.dto.response.SpotResponse;
import com.parking.booking.dto.response.VehicleSessionResponse;
import com.parking.booking.exception.ResourceAlreadyExistsException;
import com.parking.booking.exception.ResourceNotFoundException;
import com.parking.booking.feign.AdminServiceClient;
import com.parking.booking.kafka.BookingEvent;
import com.parking.booking.kafka.KafkaProducerService;
import com.parking.booking.model.Booking;
import com.parking.booking.model.VehicleSession;
import com.parking.booking.repository.BookingRepository;
import com.parking.booking.repository.VehicleSessionRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.math.BigDecimal;
import java.time.LocalDateTime;
import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyBoolean;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.doNothing;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.times;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
@DisplayName("BookingService Unit Tests")
class BookingServiceTest {

    @Mock
    private BookingRepository bookingRepository;

    @Mock
    private VehicleSessionRepository vehicleSessionRepository;

    @Mock
    private AdminServiceClient adminServiceClient;

    @Mock
    private KafkaProducerService kafkaProducerService;

    @InjectMocks
    private BookingService bookingService;

    private BookingRequest bookingRequest;
    private SpotResponse availableSpot;
    private SpotResponse occupiedSpot;
    private Booking mockBooking;
    private VehicleSession mockSession;
    private FeeConfigResponse feeConfig;

    @BeforeEach
    void setUp() {
        bookingRequest = new BookingRequest();
        bookingRequest.setSpotId("spot-123");
        bookingRequest.setVehicleNumber("MH12AB1234");
        bookingRequest.setVehicleType("FOUR_WHEELER");
        bookingRequest.setEntryGateId("gate-456");

        availableSpot = new SpotResponse();
        availableSpot.setId("spot-123");
        availableSpot.setSpotCode("G-001");
        availableSpot.setVehicleType("FOUR_WHEELER");
        availableSpot.setOccupied(false);
        availableSpot.setActive(true);

        occupiedSpot = new SpotResponse();
        occupiedSpot.setId("spot-123");
        occupiedSpot.setOccupied(true);
        occupiedSpot.setActive(true);

        mockBooking = Booking.builder()
                .id("booking-789")
                .userId("user-123")
                .spotId("spot-123")
                .status("ACTIVE")
                .vehicleNumber("MH12AB1234")
                .vehicleType("FOUR_WHEELER")
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        mockSession = VehicleSession.builder()
                .id("session-001")
                .bookingId("booking-789")
                .entryGateId("gate-456")
                .vehicleNumber("MH12AB1234")
                .entryTime(LocalDateTime.now().minusHours(2))
                .build();

        feeConfig = new FeeConfigResponse();
        feeConfig.setVehicleType("FOUR_WHEELER");
        feeConfig.setRatePerHour(BigDecimal.valueOf(50));
        feeConfig.setGraceMinutes(15);
        feeConfig.setActive(true);
    }

    // ─── Create Booking Tests ─────────────────────────────

    @Test
    @DisplayName("Should create booking successfully")
    void createBooking_Success() {
        // Arrange
        com.parking.booking.dto.response.ApiResponse<SpotResponse>
                spotResponse = new com.parking.booking
                        .dto.response.ApiResponse<>();
        spotResponse.setData(availableSpot);

        when(adminServiceClient.getSpotById(
                anyString(), anyString()))
                .thenReturn(spotResponse);
        when(adminServiceClient.markSpotOccupied(
                anyString(), anyString(), anyBoolean()))
                .thenReturn(null);
        when(bookingRepository
                .existsActiveBookingForSpot(anyString()))
                .thenReturn(false);
        doNothing().when(bookingRepository)
                .save(any(Booking.class));
        doNothing().when(vehicleSessionRepository)
                .save(any(VehicleSession.class));
        doNothing().when(bookingRepository)
                .updateStatus(anyString(), anyString());
        when(bookingRepository.findById(anyString()))
                .thenReturn(Optional.of(mockBooking));
        doNothing().when(kafkaProducerService)
                .publishBookingCreated(any(BookingEvent.class));

        // Act
        BookingResponse response =
                bookingService.createBooking(
                        "user-123", bookingRequest);

        // Assert
        assertThat(response).isNotNull();
        assertThat(response.getVehicleNumber())
                .isEqualTo("MH12AB1234");
        assertThat(response.getStatus())
                .isEqualTo("ACTIVE");

        verify(bookingRepository, times(1))
                .save(any(Booking.class));
        verify(vehicleSessionRepository, times(1))
                .save(any(VehicleSession.class));
    }

    @Test
    @DisplayName("Should throw exception when spot occupied")
    void createBooking_SpotOccupied_ThrowsException() {
        // Arrange
        com.parking.booking.dto.response.ApiResponse<SpotResponse>
                spotResponse = new com.parking.booking
                        .dto.response.ApiResponse<>();
        spotResponse.setData(occupiedSpot);

        when(adminServiceClient.getSpotById(
                anyString(), anyString()))
                .thenReturn(spotResponse);

        // Act & Assert
        assertThatThrownBy(() ->
                bookingService.createBooking(
                        "user-123", bookingRequest))
                .isInstanceOf(
                        ResourceAlreadyExistsException.class)
                .hasMessageContaining(
                        "Spot is already occupied");

        verify(bookingRepository, never())
                .save(any(Booking.class));
    }

    @Test
    @DisplayName("Should throw exception when spot not found")
    void createBooking_SpotNotFound_ThrowsException() {
        // Arrange
        com.parking.booking.dto.response.ApiResponse<SpotResponse>
                spotResponse = new com.parking.booking
                        .dto.response.ApiResponse<>();
        spotResponse.setData(null);

        when(adminServiceClient.getSpotById(
                anyString(), anyString()))
                .thenReturn(spotResponse);

        // Act & Assert
        assertThatThrownBy(() ->
                bookingService.createBooking(
                        "user-123", bookingRequest))
                .isInstanceOf(
                        ResourceNotFoundException.class)
                .hasMessageContaining(
                        "Spot not found or inactive");
    }

    // ─── Get Booking Tests ────────────────────────────────

    @Test
    @DisplayName("Should return booking by ID")
    void getBookingById_Success() {
        // Arrange
        when(bookingRepository.findById("booking-789"))
                .thenReturn(Optional.of(mockBooking));

        // Act
        BookingResponse response =
                bookingService.getBookingById("booking-789");

        // Assert
        assertThat(response).isNotNull();
        assertThat(response.getId())
                .isEqualTo("booking-789");
        assertThat(response.getStatus())
                .isEqualTo("ACTIVE");
    }

    @Test
    @DisplayName("Should throw when booking not found")
    void getBookingById_NotFound_ThrowsException() {
        // Arrange
        when(bookingRepository.findById(anyString()))
                .thenReturn(Optional.empty());

        // Act & Assert
        assertThatThrownBy(() ->
                bookingService.getBookingById("invalid"))
                .isInstanceOf(
                        ResourceNotFoundException.class)
                .hasMessageContaining("Booking not found");
    }

    // ─── Cancel Booking Tests ─────────────────────────────

    @Test
    @DisplayName("Should cancel booking successfully")
    void cancelBooking_Success() {
        // Arrange
        when(bookingRepository.findById("booking-789"))
                .thenReturn(Optional.of(mockBooking));
        doNothing().when(bookingRepository)
                .updateStatus(anyString(), anyString());
        when(adminServiceClient.markSpotOccupied(
                anyString(), anyString(), anyBoolean()))
                .thenReturn(null);
        doNothing().when(kafkaProducerService)
                .publishBookingCancelled(
                        any(BookingEvent.class));

        Booking cancelledBooking = Booking.builder()
                .id("booking-789")
                .userId("user-123")
                .spotId("spot-123")
                .status("CANCELLED")
                .vehicleNumber("MH12AB1234")
                .vehicleType("FOUR_WHEELER")
                .createdAt(LocalDateTime.now())
                .updatedAt(LocalDateTime.now())
                .build();

        when(bookingRepository.findById("booking-789"))
                .thenReturn(Optional.of(mockBooking))
                .thenReturn(Optional.of(cancelledBooking));

        // Act
        BookingResponse response =
