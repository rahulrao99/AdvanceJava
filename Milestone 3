import React, { useState, useEffect } from 'react';
import { Container, Typography, Box, Grid } from '@mui/material';
import SearchBar from '../components/SearchBar';
import MovieCard from '../components/MovieCard';
import Loading from '../components/Loading';
import ErrorMessage from '../components/ErrorMessage';
import { searchMovies } from '../services/movieService';

const HomePage = () => {
  const [movies, setMovies] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');

  useEffect(() => {
    const fetchPopular = async () => {
      try {
        setLoading(true);
        const data = await searchMovies('marvel');
        setMovies(data);
      } catch (err) {
        setError('Failed to load popular movies.');
      } finally {
        setLoading(false);
      }
    };
    fetchPopular();
  }, []);

  return (
    <Box sx={{ backgroundColor: '#141414', minHeight: '100vh', py: 4 }}>
      <Container maxWidth="lg">
        <Typography variant="h4" color="#e50914" fontWeight={700} textAlign="center" mb={1}>
          🎬 CineSearch
        </Typography>
        <Typography variant="subtitle1" color="#aaa" textAlign="center" mb={3}>
          Search millions of movies instantly
        </Typography>

        <SearchBar />

        <Typography variant="h5" color="#fff" fontWeight={700} mt={5} mb={3}>
          🔥 Popular Movies
        </Typography>

        {loading && <Loading />}
        {error && <ErrorMessage message={error} />}

        {!loading && !error && (
          <Grid container spacing={3}>
            {movies.map((movie) => (
              <Grid item xs={12} sm={6} md={4} lg={3} key={movie.imdbID}>
                <MovieCard movie={movie} />
              </Grid>
            ))}
          </Grid>
        )}
      </Container>
    </Box>
  );
};

export default HomePage;
```

