Step 9 — Repository
Right-click com.parking.receipt.repository → New → Java Class → ReceiptRepository
javapackage com.parking.receipt.repository;

import com.parking.receipt.model.Receipt;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.core.RowMapper;
import org.springframework.stereotype.Repository;

import java.util.List;
import java.util.Optional;

@Slf4j
@Repository
@RequiredArgsConstructor
public class ReceiptRepository {

    private final JdbcTemplate jdbcTemplate;

    private final RowMapper<Receipt> rowMapper = (rs, rowNum) ->
            Receipt.builder()
                    .id(rs.getString("id"))
                    .bookingId(rs.getString("booking_id"))
                    .sessionId(rs.getString("session_id"))
                    .receiptType(rs.getString("receipt_type"))
                    .emailSent(rs.getBoolean("email_sent"))
                    .generatedAt(rs.getTimestamp("generated_at")
                            .toLocalDateTime())
                    .build();

    public void save(Receipt receipt) {
        log.debug("Saving receipt for booking: {}",
                receipt.getBookingId());
        String sql = """
                INSERT INTO receipts
                (id, booking_id, session_id, receipt_type,
                 email_sent, generated_at)
                VALUES (?, ?, ?, ?, ?, NOW())
                """;
        jdbcTemplate.update(sql,
                receipt.getId(),
                receipt.getBookingId(),
                receipt.getSessionId(),
                receipt.getReceiptType(),
                receipt.isEmailSent()
        );
    }

    public Optional<Receipt> findById(String id) {
        String sql = "SELECT * FROM receipts WHERE id = ?";
        return jdbcTemplate.query(sql, rowMapper, id)
                .stream().findFirst();
    }

    public List<Receipt> findByBookingId(String bookingId) {
        String sql = """
                SELECT * FROM receipts
                WHERE booking_id = ?
                ORDER BY generated_at ASC
                """;
        return jdbcTemplate.query(sql, rowMapper, bookingId);
    }

    public List<Receipt> findByBookingIdAndType(
            String bookingId, String receiptType) {
        String sql = """
                SELECT * FROM receipts
                WHERE booking_id = ?
                AND receipt_type = ?
                """;
        return jdbcTemplate.query(sql, rowMapper,
                bookingId, receiptType);
    }
}

