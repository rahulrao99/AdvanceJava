Step 11 — ReceiptService
Right-click com.parking.receipt.service → New → Java Class → ReceiptService
What this does: Generates receipts when triggered by Kafka events. For entry receipt — records vehicle entry details. For exit receipt — records full session with duration and fee.
javapackage com.parking.receipt.service;

import com.parking.receipt.dto.response.ReceiptResponse;
import com.parking.receipt.exception.ResourceNotFoundException;
import com.parking.receipt.kafka.BookingEvent;
import com.parking.receipt.model.Receipt;
import com.parking.receipt.repository.ReceiptRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.util.List;
import java.util.UUID;

@Slf4j
@Service
@RequiredArgsConstructor
public class ReceiptService {

    private final ReceiptRepository receiptRepository;

    public ReceiptResponse generateEntryReceipt(
            BookingEvent event) {
        log.info("Generating entry receipt for booking: {}",
                event.getBookingId());

        String receiptNumber = "RCP-ENT-"
                + UUID.randomUUID().toString()
                        .substring(0, 8).toUpperCase();

        Receipt receipt = Receipt.builder()
                .id(UUID.randomUUID().toString())
                .bookingId(event.getBookingId())
                .receiptType("ENTRY")
                .receiptNumber(receiptNumber)
                .vehicleNumber(event.getVehicleNumber())
                .vehicleType(event.getVehicleType())
                .entryTime(LocalDateTime.now())
                .emailSent(false)
                .build();

        receiptRepository.save(receipt);
        log.info("Entry receipt generated: {}", receiptNumber);

        return mapToResponse(receipt);
    }

    public ReceiptResponse generateExitReceipt(
            BookingEvent event) {
        log.info("Generating exit receipt for booking: {}",
                event.getBookingId());

        String receiptNumber = "RCP-EXT-"
                + UUID.randomUUID().toString()
                        .substring(0, 8).toUpperCase();

        Receipt receipt = Receipt.builder()
                .id(UUID.randomUUID().toString())
                .bookingId(event.getBookingId())
                .receiptType("EXIT")
                .receiptNumber(receiptNumber)
                .vehicleNumber(event.getVehicleNumber())
                .vehicleType(event.getVehicleType())
                .feeCharged(event.getAmount())
                .exitTime(LocalDateTime.now())
                .emailSent(false)
                .build();

        receiptRepository.save(receipt);
        log.info("Exit receipt generated: {}", receiptNumber);

        return mapToResponse(receipt);
    }

    public List<ReceiptResponse> getReceiptsByBooking(
            String bookingId) {
        log.info("Fetching receipts for booking: {}",
                bookingId);
        return receiptRepository.findByBookingId(bookingId)
                .stream()
                .map(this::mapToResponse)
                .toList();
    }

    public ReceiptResponse getReceiptById(String receiptId) {
        log.info("Fetching receipt: {}", receiptId);
        return receiptRepository.findById(receiptId)
                .map(this::mapToResponse)
                .orElseThrow(() ->
                        new ResourceNotFoundException(
                                "Receipt not found: "
                                        + receiptId));
    }

    private ReceiptResponse mapToResponse(Receipt receipt) {
        return ReceiptResponse.builder()
                .id(receipt.getId())
                .bookingId(receipt.getBookingId())
                .receiptType(receipt.getReceiptType())
                .receiptNumber(receipt.getReceiptNumber())
                .vehicleNumber(receipt.getVehicleNumber())
                .vehicleType(receipt.getVehicleType())
                .spotCode(receipt.getSpotCode())
                .lotName(receipt.getLotName())
                .entryTime(receipt.getEntryTime())
                .exitTime(receipt.getExitTime())
                .durationMinutes(receipt.getDurationMinutes())
                .feeCharged(receipt.getFeeCharged())
                .emailSent(receipt.isEmailSent())
                .generatedAt(receipt.getGeneratedAt())
                .build();
    }
}

Step 12 — Kafka Consumer
Right-click com.parking.receipt.kafka → New → Java Class → ReceiptKafkaConsumer
What this does: Listens to Kafka topics. When booking.created event arrives → generates entry receipt. When vehicle.exit event arrives → generates exit receipt.
javapackage com.parking.receipt.kafka;

import com.parking.receipt.service.ReceiptService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;

@Slf4j
@Component
@RequiredArgsConstructor
public class ReceiptKafkaConsumer {

    private final ReceiptService receiptService;

    @KafkaListener(
        topics = "booking.created",
        groupId = "receipt-service-group")
    public void handleBookingCreated(BookingEvent event) {
        log.info("Received booking.created event: {}",
                event.getBookingId());
        try {
            receiptService.generateEntryReceipt(event);
            log.info("Entry receipt generated for booking: {}",
                    event.getBookingId());
        } catch (Exception e) {
            log.error("Failed to generate entry receipt: {}",
                    e.getMessage());
        }
    }

    @KafkaListener(
        topics = "vehicle.exit",
        groupId = "receipt-service-group")
    public void handleVehicleExit(BookingEvent event) {
        log.info("Received vehicle.exit event: {}",
                event.getBookingId());
        try {
            receiptService.generateExitReceipt(event);
            log.info("Exit receipt generated for booking: {}",
                    event.getBookingId());
        } catch (Exception e) {
            log.error("Failed to generate exit receipt: {}",
                    e.getMessage());
        }
    }
}

