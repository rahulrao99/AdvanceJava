Fix 3 — Add PDF Download Endpoint
For auto-download of receipt as PDF, add this to ReceiptController.java:
java@GetMapping("/{receiptId}/download")
public ResponseEntity<byte[]> downloadReceipt(
        @PathVariable("receiptId") String receiptId) {
    log.info("Downloading receipt: {}", receiptId);

    ReceiptResponse receipt =
            receiptService.getReceiptById(receiptId);

    // Generate PDF content as text
    String content = generateReceiptContent(receipt);
    byte[] pdfBytes = content.getBytes();

    return ResponseEntity.ok()
            .header("Content-Type", "application/pdf")
            .header("Content-Disposition",
                    "attachment; filename=\""
                    + receipt.getReceiptNumber()
                    + ".pdf\"")
            .body(pdfBytes);
}

private String generateReceiptContent(
        ReceiptResponse receipt) {
    return """
            ============================================
            VEHICLE PARKING MANAGEMENT SYSTEM
            ============================================
            Receipt Number : %s
            Receipt Type   : %s
            ============================================
            Vehicle Number : %s
            Vehicle Type   : %s
            Lot Name       : %s
            Spot Code      : %s
            Level          : %s
            ============================================
            Entry Time     : %s
            Exit Time      : %s
            Duration       : %s minutes
            Fee Charged    : Rs. %s
            ============================================
            Generated At   : %s
            ============================================
            Thank you for using Central Parking!
            ============================================
            """.formatted(
                receipt.getReceiptNumber(),
                receipt.getReceiptType(),
                receipt.getVehicleNumber() != null
                        ? receipt.getVehicleNumber() : "N/A",
                receipt.getVehicleType() != null
                        ? receipt.getVehicleType() : "N/A",
                receipt.getLotName() != null
                        ? receipt.getLotName() : "N/A",
                receipt.getSpotCode() != null
                        ? receipt.getSpotCode() : "N/A",
                receipt.getLevelLabel() != null
                        ? receipt.getLevelLabel() : "N/A",
                receipt.getEntryTime() != null
                        ? receipt.getEntryTime() : "N/A",
                receipt.getExitTime() != null
                        ? receipt.getExitTime() : "N/A",
                receipt.getDurationMinutes() != null
                        ? receipt.getDurationMinutes() : 0,
                receipt.getFeeCharged() != null
                        ? receipt.getFeeCharged() : 0,
                receipt.getGeneratedAt()
            );
}

