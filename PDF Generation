Fix 1 — Generate Receipt Manually (Without Kafka)
Since Kafka is not running, let's add a manual receipt generation endpoint that gets triggered directly from Booking Service after exit.

Add to ReceiptController.java
java@PostMapping("/generate")
public ResponseEntity<ApiResponse<ReceiptResponse>>
        generateReceipt(
            @Valid @RequestBody GenerateReceiptRequest request) {
    log.info("Manual receipt generation for booking: {}",
            request.getBookingId());
    ReceiptResponse response =
            receiptService.generateReceiptManually(request);
    return ResponseEntity
            .status(HttpStatus.CREATED)
            .body(ApiResponse.success(
                    "Receipt generated", response));
}
Add GenerateReceiptRequest.java
Right-click com.parking.receipt.dto.request → New → Java Class
javapackage com.parking.receipt.dto.request;

import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.Pattern;
import lombok.Data;

@Data
public class GenerateReceiptRequest {

    @NotBlank(message = "Booking ID is required")
    private String bookingId;

    @NotBlank(message = "Receipt type is required")
    @Pattern(
        regexp = "ENTRY|EXIT",
        message = "Receipt type must be ENTRY or EXIT"
    )
    private String receiptType;

    private String vehicleNumber;
    private String vehicleType;
    private java.math.BigDecimal feeCharged;
}
Add generateReceiptManually() in ReceiptService.java
javapublic ReceiptResponse generateReceiptManually(
        GenerateReceiptRequest request) {
    log.info("Generating {} receipt for booking: {}",
            request.getReceiptType(),
            request.getBookingId());

    String prefix = request.getReceiptType()
            .equals("ENTRY") ? "ENT" : "EXT";
    String receiptNumber = "RCP-" + prefix + "-"
            + UUID.randomUUID().toString()
                    .substring(0, 8).toUpperCase();

    Receipt receipt = Receipt.builder()
            .id(UUID.randomUUID().toString())
            .bookingId(request.getBookingId())
            .receiptType(request.getReceiptType())
            .receiptNumber(receiptNumber)
            .vehicleNumber(request.getVehicleNumber())
            .vehicleType(request.getVehicleType())
            .feeCharged(request.getFeeCharged())
            .entryTime(request.getReceiptType()
                    .equals("ENTRY")
                    ? LocalDateTime.now() : null)
            .exitTime(request.getReceiptType()
                    .equals("EXIT")
                    ? LocalDateTime.now() : null)
            .emailSent(false)
            .build();

    receiptRepository.save(receipt);
    log.info("Receipt generated: {}", receiptNumber);

    return mapToResponse(receipt);
}

