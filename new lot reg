@Operation(
    summary = "Register admin",
    description = "Creates admin user. Only ROLE_ADMIN can call this.")
@PostMapping("/register-admin")
@PreAuthorize("hasAuthority('ROLE_ADMIN')")
public ResponseEntity<ApiResponse<UserResponse>> registerAdmin(
        @Valid @RequestBody RegisterRequest request) {
    log.info("Admin register request for email: {}",
            request.getEmail());
    UserResponse user = userService.registerAdmin(request);
    return ResponseEntity
            .status(HttpStatus.CREATED)
            .body(ApiResponse.success(
                    "Admin registered successfully", user));
}

