package com.parking.booking.repository;

import com.parking.booking.model.Booking;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.core.RowMapper;
import org.springframework.stereotype.Repository;

import java.util.List;
import java.util.Optional;

@Slf4j
@Repository
@RequiredArgsConstructor
public class BookingRepository {

    private final JdbcTemplate jdbcTemplate;

    private final RowMapper<Booking> rowMapper = (rs, rowNum) ->
            Booking.builder()
                    .id(rs.getString("id"))
                    .userId(rs.getString("user_id"))
                    .spotId(rs.getString("spot_id"))
                    .status(rs.getString("status"))
                    .startTime(rs.getTimestamp("start_time")
                            .toLocalDateTime())
                    .endTime(rs.getTimestamp("end_time") != null
                            ? rs.getTimestamp("end_time").toLocalDateTime()
                            : null)
                    .amount(rs.getBigDecimal("amount"))
                    .vehicleNumber(rs.getString("vehicle_number"))
                    .vehicleType(rs.getString("vehicle_type"))
                    .createdAt(rs.getTimestamp("created_at")
                            .toLocalDateTime())
                    .updatedAt(rs.getTimestamp("updated_at")
                            .toLocalDateTime())
                    .build();

    public void save(Booking booking) {
        log.debug("Saving booking: {}", booking.getId());
        String sql = """
                INSERT INTO bookings
                (id, user_id, spot_id, status, start_time,
                 vehicle_number, vehicle_type, created_at, updated_at)
                VALUES (?, ?, ?, ?, NOW(), ?, ?, NOW(), NOW())
                """;
        jdbcTemplate.update(sql,
                booking.getId(),
                booking.getUserId(),
                booking.getSpotId(),
                booking.getStatus(),
                booking.getVehicleNumber(),
                booking.getVehicleType()
        );
    }

    public Optional<Booking> findById(String id) {
        String sql = "SELECT * FROM bookings WHERE id = ?";
        return jdbcTemplate.query(sql, rowMapper, id)
                .stream().findFirst();
    }

    public List<Booking> findByUserId(String userId,
                                       int offset, int size) {
        String sql = """
                SELECT * FROM bookings
                WHERE user_id = ?
                ORDER BY created_at DESC
                LIMIT ? OFFSET ?
                """;
        return jdbcTemplate.query(sql, rowMapper,
                userId, size, offset);
    }

    public long countByUserId(String userId) {
        String sql = """
                SELECT COUNT(*) FROM bookings WHERE user_id = ?
                """;
        Long count = jdbcTemplate.queryForObject(
                sql, Long.class, userId);
        return count != null ? count : 0;
    }

    public void updateStatus(String bookingId, String status) {
        log.debug("Updating booking status: {} → {}", 
                  bookingId, status);
        String sql = """
                UPDATE bookings
                SET status = ?, updated_at = NOW()
                WHERE id = ?
                """;
        jdbcTemplate.update(sql, status, bookingId);
    }

    public void updateStatusAndAmount(String bookingId,
                                       String status,
                                       java.math.BigDecimal amount) {
        String sql = """
                UPDATE bookings
                SET status = ?, amount = ?,
                    end_time = NOW(), updated_at = NOW()
                WHERE id = ?
                """;
        jdbcTemplate.update(sql, status, amount, bookingId);
    }

    public boolean existsActiveBookingForSpot(String spotId) {
        String sql = """
                SELECT COUNT(*) FROM bookings
                WHERE spot_id = ?
                AND status IN ('PENDING','CONFIRMED','ACTIVE')
                """;
        Integer count = jdbcTemplate.queryForObject(
                sql, Integer.class, spotId);
        return count != null && count > 0;
    }
}
