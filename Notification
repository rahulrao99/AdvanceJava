What this does: Listens to Kafka topics. When events arrive from Booking Service, it triggers email sending.
javapackage com.parking.notification.kafka;

import com.parking.notification.service.NotificationService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;

@Slf4j
@Component
@RequiredArgsConstructor
public class NotificationKafkaConsumer {

    private final NotificationService notificationService;

    @KafkaListener(
        topics = "booking.created",
        groupId = "notification-service-group")
    public void handleBookingCreated(
            NotificationEvent event) {
        log.info("Received booking.created: {}",
                event.getBookingId());
        notificationService.processBookingCreated(event);
    }

    @KafkaListener(
        topics = "vehicle.exit",
        groupId = "notification-service-group")
    public void handleVehicleExit(NotificationEvent event) {
        log.info("Received vehicle.exit: {}",
                event.getBookingId());
        notificationService.processVehicleExit(event);
    }

    @KafkaListener(
        topics = "booking.cancelled",
        groupId = "notification-service-group")
    public void handleBookingCancelled(
            NotificationEvent event) {
        log.info("Received booking.cancelled: {}",
                event.getBookingId());
        // Can add cancellation email here
    }

    @KafkaListener(
        topics = "payment.completed",
        groupId = "notification-service-group")
    public void handlePaymentCompleted(
            NotificationEvent event) {
        log.info("Received payment.completed: {}",
                event.getBookingId());
        // Can add payment success email here
    }
}

