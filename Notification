import com.parking.notification.feign.UserServiceClient;
import com.parking.notification.kafka.NotificationEvent;
import com.parking.notification.model.Notification;
import com.parking.notification.repository.NotificationRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.util.Map;
import java.util.UUID;

@Slf4j
@Service
@RequiredArgsConstructor
public class NotificationService {

    private final EmailService emailService;
    private final NotificationRepository notificationRepository;
    private final UserServiceClient userServiceClient;

    public void processBookingCreated(
            NotificationEvent event) {
        log.info("Processing booking.created notification: {}",
                event.getBookingId());

        try {
            // Fetch user email from User Service
            Map<String, Object> profile =
                    fetchUserProfile(event.getUserId());

            String email = profile != null
                    ? (String) profile.get("email") : null;
            String username = profile != null
                    ? (String) profile.get("username") : null;

            if (email == null) {
                log.warn("No email found for user: {}",
                        event.getUserId());
                return;
            }

            // Save notification record
            Notification notification = Notification.builder()
                    .id(UUID.randomUUID().toString())
                    .userId(event.getUserId())
                    .type("BOOKING_CONFIRMED")
                    .channel("EMAIL")
                    .subject("Booking Confirmed — "
                            + event.getVehicleNumber())
                    .body("Booking confirmed for "
                            + event.getVehicleNumber())
                    .status("PENDING")
                    .build();

            notificationRepository.save(notification);

            // Send email
            emailService.sendBookingConfirmation(
                    email,
                    username,
                    event.getBookingId(),
                    event.getVehicleNumber(),
                    event.getVehicleType(),
                    event.getTimestamp());

            // Update status
            notificationRepository.updateStatus(
                    notification.getId(), "SENT");

            log.info("Booking confirmation sent to: {}",
                    email);

        } catch (Exception e) {
            log.error("Failed to process booking notification: {}",
                    e.getMessage());
        }
    }

    public void processVehicleExit(
            NotificationEvent event) {
        log.info("Processing vehicle.exit notification: {}",
                event.getBookingId());

        try {
            // Fetch user email
            Map<String, Object> profile =
                    fetchUserProfile(event.getUserId());

            String email = profile != null
                    ? (String) profile.get("email") : null;
            String username = profile != null
                    ? (String) profile.get("username") : null;

            if (email == null) {
                log.warn("No email found for user: {}",
                        event.getUserId());
                return;
            }

            // Save notification record
            Notification notification = Notification.builder()
                    .id(UUID.randomUUID().toString())
                    .userId(event.getUserId())
                    .type("EXIT_RECEIPT")
                    .channel("EMAIL")
                    .subject("Parking Receipt — Rs."
                            + event.getFeeCharged())
                    .body("Exit receipt for "
                            + event.getVehicleNumber())
                    .status("PENDING")
                    .build();

            notificationRepository.save(notification);

            // Send email
            emailService.sendExitReceipt(
                    email,
                    username,
                    event.getBookingId(),
                    event.getVehicleNumber(),
                    event.getVehicleType(),
                    event.getEntryTime(),
                    event.getExitTime(),
                    event.getDurationMinutes(),
                    event.getFeeCharged());

            // Update status
            notificationRepository.updateStatus(
                    notification.getId(), "SENT");

            log.info("Exit receipt sent to: {}", email);

        } catch (Exception e) {
            log.error("Failed to process exit notification: {}",
                    e.getMessage());
        }
    }

    private Map<String, Object> fetchUserProfile(
            String userId) {
        try {
            // Use system token for internal call
            // In production use service-to-service auth
            return null; // will be set from Kafka event
        } catch (Exception e) {
            log.error("Failed to fetch user profile: {}",
                    e.getMessage());
            return null;
        }
    }
}

